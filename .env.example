# Anthropic / Claude Code
ANTHROPIC_API_KEY=                 # OR rely on claude-code subscription

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=         # comma-separated
TELEGRAM_PRIMARY_CHAT_ID=          # single chat ID for scheduled mission delivery
BRIDGE_INTERNAL_PORT=3142          # loopback port: bridge listens, scheduler posts here

# Gemini (memory extraction + Live voice)
GEMINI_API_KEY=

# Dashboard
DASHBOARD_PORT=3141
DASHBOARD_PIN=                     # 6 digits

# War Room
WARROOM_PORT=7860

# SQLite
DB_PATH=./store/claudeclaw.db
DB_ENCRYPTION_KEY=                 # optional, sqlcipher

# Cloudflare tunnel (optional)
CLOUDFLARE_TUNNEL_TOKEN=

# Optional services
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
DAILY_API_KEY=
PIKA_API_KEY=
NANO_BANANA_API_KEY=

# V3 kill switches (page 4 + page 5)
MISSION_AUTO_ASSIGN_ENABLED=true   # "false" forces manual task routing
SCHEDULER_ENABLED=true             # "false" halts all cron missions without restart
KILL_PHRASE=seven kingdoms fall    # text or voice; halts sessions, clears secrets

# Meta Ads skill (transcript ch.6)
META_DEFAULT_ACCOUNT_ID=
META_ADS_CLI_PATH=meta-ads-cli     # absolute path or PATH-resolvable name
